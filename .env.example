PORT=3000

# Git Provider: "github" or "gitea"
GIT_PROVIDER=gitea

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=freischule
# "user" (default) → /users/:owner/repos  |  "org" → /orgs/:owner/repos
GITHUB_OWNER_TYPE=user

# Gitea
GITEA_BASE_URL=https://gitea.freischule.info
GITEA_TOKEN=your-gitea-token
GITEA_OWNER=freischule
# "user" (default) → /users/:owner/repos  |  "org" → /orgs/:owner/repos
GITEA_OWNER_TYPE=user

# MongoDB (API key store, runs on the Strato server)
MONGODB_URI=mongodb://user:password@host:27017/gitservice?authSource=admin
MONGODB_DB=gitservice

# AuthService (for JWT public key — fetched once on startup)
AUTH_SERVICE_URL=https://auth.freischule.info

# EmailService
EMAIL_SERVICE_URL=https://email.freischule.info
EMAIL_SERVICE_API_KEY=your-email-service-api-key
EMAIL_FROM=gitservice@flussmark.de
EMAIL_REPLY_TO=gitservice@flussmark.de

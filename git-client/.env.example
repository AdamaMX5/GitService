# GitService
GIT_SERVICE_URL=https://git.freischule.info

# Auth: by default the client logs in with the GITCLIENT account (role-based).
# On the FIRST start you are prompted for the GITCLIENT email + password
# interactively; tokens are then cached under ~/.gitclient/tokens.json and
# refreshed automatically. No API key needed.
#
# Optional fallback: set GIT_SERVICE_API_KEY to use X-API-Key auth instead.
# If set, it takes precedence over the GITCLIENT login — leave it empty/unset
# to use the role-based account.
# GIT_SERVICE_API_KEY=

# AuthService (for GITCLIENT account login)
AUTH_SERVICE_URL=https://auth.freischule.info

# Local repo directories: comma-separated name:path pairs
# Windows example:  freischule-backend:C:\Users\Kurt\git\freischule-backend
# Linux example:    freischule-backend:/home/kurt/git/freischule-backend
REPO_PATHS=freischule-backend:/home/kurt/git/freischule-backend,freischule-frontend:/home/kurt/git/freischule-frontend

# Polling interval in seconds (default: 60)
POLL_INTERVAL=60
